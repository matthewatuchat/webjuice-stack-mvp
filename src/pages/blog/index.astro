---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog - WebJuice">
  <h1 class="text-4xl font-bold mb-4">Blog</h1>
  <p class="text-gray-600 mb-12">Thoughts on B2B marketing, web performance, and our stack.</p>
  
  <div class="space-y-10">
    {sorted.map(post => (
      <article class="border-b border-gray-100 pb-10">
        <a href={`/blog/${post.slug}`} class="group block">
          <h2 class="text-2xl font-semibold group-hover:text-gray-600 mb-2">{post.data.title}</h2>
          <p class="text-gray-600 mb-3">{post.data.description}</p>
          <div class="flex items-center gap-3 text-sm text-gray-400">
            <span>{post.data.author}</span>
            <span>&middot;</span>
            <span>{post.data.pubDate.toLocaleDateString()}</span>
          </div>
        </a>
      </article>
    ))}
  </div>
</Layout>
